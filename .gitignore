# Build output
bin/
obj/

# Include deployment binaries (but never .config — contains connection strings)
!PolyMonExecutive/bin/
!PolyMonManager/bin/
PolyMonExecutive/bin/*.config
PolyMonManager/bin/*.config
*.InstallLog
*.InstallState
*.suo
*.user
*.cache
BuildAnalysis.txt

# Installer staging and build output
PolyMonInstall/
Output/
PolyMon-Setup.exe

# Build logs
BuildAnalysis.txt

# Keep resource/content txt files but exclude obj build logs
obj/**/*.txt

# Ansible playbooks (infrastructure, not part of PolyMon app)
ansible/
.aider*
